generator client {
  provider = "prisma-client-js"
}


enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentProvider {
  XTRANSFER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
}

enum AdminRole {
  ADMIN
  OPERATOR
  VIEWER
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id            String   @id @default(uuid()) @db.Uuid
  slug          String   @unique
  name          String
  tagline       String?
  description   String?
  ingredients   String?
  howToUse      String?  @map("how_to_use")
  price         Decimal  @db.Decimal(10, 2)
  comparePrice  Decimal? @map("compare_price") @db.Decimal(10, 2)
  category      String?
  skinConcerns  String[] @map("skin_concerns")
  badge         String?
  rating        Decimal  @default(0) @db.Decimal(2, 1)
  reviewsCount  Int      @default(0) @map("reviews_count")
  size          String?
  images        String[]
  isActive      Boolean  @default(true) @map("is_active")
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  variants  ProductVariant[]
  orderItems OrderItem[]
  reviews   Review[]
  caseStudyProductsUsed CaseStudyProductUsed[]

  @@map("products")
}

model ProductVariant {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  name      String
  size      String?
  price     Decimal? @db.Decimal(10, 2)
  sku       String?  @unique
  stock     Int      @default(0)

  product              Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryTransactions InventoryTransaction[]

  @@map("product_variants")
}

model Order {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String?  @map("user_id") @db.Uuid
  status          String   @default("pending")
  total           Decimal  @db.Decimal(10, 2)
  shippingAddress Json?    @map("shipping_address")
  stripeSessionId  String?  @map("stripe_session_id")
  metadata         Json?
  orderNumber      String?  @map("order_number")
  cartFingerprint  String?  @map("cart_fingerprint")
  paymentIntentId  String?  @map("payment_intent_id")
  email            String?
  customerEmail     String?  @map("customer_email")
  customerName      String?  @map("customer_name")
  customerPhone     String?  @map("customer_phone")
  subtotal          Decimal? @db.Decimal(10, 2)
  shippingFee       Decimal? @db.Decimal(10, 2) @map("shipping_fee")
  tax               Decimal? @db.Decimal(10, 2)
  currency          String   @default("USD")
  shippingName      String?  @map("shipping_name")
  shippingPhone     String?  @map("shipping_phone")
  shippingAddress1  String?  @map("shipping_address1")
  shippingAddress2  String?  @map("shipping_address2")
  shippingCity      String?  @map("shipping_city")
  shippingProvince  String?  @map("shipping_province")
  shippingPostal    String?  @map("shipping_postal")
  shippingCountry   String?  @map("shipping_country")
  customerNote      String?  @map("customer_note")
  adminNote         String?  @map("admin_note")
  paidAt            DateTime? @map("paid_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  statusHistory OrderStatusHistory[]
  createdAt        DateTime @default(now()) @map("created_at")

  items OrderItem[]
  payments Payment[]
  auditLogs OrderAuditLog[]

  @@index([status, createdAt])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid()) @db.Uuid
  orderId   String  @map("order_id") @db.Uuid
  productId String? @map("product_id") @db.Uuid
  quantity  Int
  price     Decimal @db.Decimal(10, 2)

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@map("order_items")
}


model Payment {
  id               String          @id @default(uuid()) @db.Uuid
  orderId          String          @map("order_id") @db.Uuid
  provider         String          @default("XTRANSFER")
  providerMetadata Json?           @map("provider_metadata")
  amount           Decimal         @db.Decimal(10, 2)
  currency         String          @default("USD")
  status           String          @default("PENDING")
  invoiceUrl       String?         @map("invoice_url")
  confirmedBy      String?         @map("confirmed_by")
  confirmedNote    String?         @map("confirmed_note")
  completedAt      DateTime?       @map("completed_at")
  createdAt        DateTime        @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@map("payments")
}


model OrderAuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  orderId        String   @map("order_id") @db.Uuid
  action         String
  performedBy    String?  @map("performed_by")
  previousStatus String?  @map("previous_status")
  newStatus      String?  @map("new_status")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@map("order_audit_logs")
}

model CaseStudy {
  id                String   @id @default(uuid()) @db.Uuid
  slug              String   @unique
  title             String
  clientName        String?  @map("client_name")
  skinConcern       String[] @map("skin_concern")
  treatmentDuration String?  @map("treatment_duration")
  description       String?
  beforeImage       String?  @map("before_image")
  afterImage        String?  @map("after_image")
  createdAt         DateTime @default(now()) @map("created_at")

  productsUsed CaseStudyProductUsed[]

  @@map("case_studies")
}

model CaseStudyProductUsed {
  caseStudyId String @map("case_study_id") @db.Uuid
  productId   String @map("product_id") @db.Uuid

  caseStudy CaseStudy @relation(fields: [caseStudyId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([caseStudyId, productId])
  @@map("case_study_products_used")
}

model BlogPost {
  id          String    @id @default(uuid()) @db.Uuid
  slug        String    @unique
  title       String
  excerpt     String?
  content     String?
  coverImage  String?   @map("cover_image")
  category    String?
  tags        String[]
  authorName  String?   @map("author_name")
  readTime    Int?      @map("read_time")
  isPublished Boolean   @default(false) @map("is_published")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  categoryRel BlogCategory? @relation(fields: [categorySlug], references: [slug])
  categorySlug String?       @map("category_slug")

  @@map("blog_posts")
}

model BlogCategory {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique
  name        String
  description String?

  posts BlogPost[]

  @@map("blog_categories")
}

model Consultation {
  id               String   @id @default(uuid()) @db.Uuid
  name             String
  email            String
  phone            String?
  consultationType String?  @map("consultation_type")
  skinType         String?  @map("skin_type")
  skinConcerns     String[] @map("skin_concerns")
  allergies        String?
  notes            String?
  calendlyEventUri String?  @map("calendly_event_uri")
  status           String   @default("pending")
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("consultations")
}

model ContactMessage {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String
  subject   String?
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_messages")
}

model Subscriber {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  subscribedAt DateTime @default(now()) @map("subscribed_at")
  isActive     Boolean  @default(true) @map("is_active")

  @@map("subscribers")
}

model Review {
  id               String   @id @default(uuid()) @db.Uuid
  productId        String   @map("product_id") @db.Uuid
  userName         String   @map("user_name")
  rating           Int
  title            String?
  body             String?
  skinType         String?  @map("skin_type")
  verifiedPurchase Boolean  @default(false) @map("verified_purchase")
  isApproved       Boolean  @default(false) @map("is_approved")
  createdAt        DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model Account {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String   @map("provider_account_id")
  refresh_token     String?  @map("refresh_token")
  access_token      String?  @map("access_token")
  expires_at        Int?     @map("expires_at")
  token_type        String?  @map("token_type")
  scope             String?
  id_token          String?  @map("id_token")
  session_state     String?  @map("session_state")

  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime

  user AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

model AdminUser {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  name          String
  passwordHash  String   @map("password_hash")
  role          String   @default("admin")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  lastLoginAt   DateTime? @map("last_login_at")
  sessions Session[]

  @@map("admin_users")
}

model InventoryTransaction {
  id          String   @id @default(uuid()) @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  variantId   String?  @map("variant_id") @db.Uuid
  type        String   // 'inbound' | 'outbound' | 'adjustment' | 'return'
  quantity    Int
  note        String?
  referenceId String?  @map("reference_id")
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  product ProductVariant? @relation(fields: [variantId], references: [id])
  @@map("inventory_transactions")
}

model AnalyticsEvent {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  properties Json?
  sessionId String?  @map("session_id")
  userId    String?  @map("user_id") @db.Uuid
  page      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([name, createdAt])
  @@map("analytics_events")
}

model ProcessedEvent {
  id             String   @id @default(uuid()) @db.Uuid
  eventId        String   @unique @map("event_id")
  type           String
  processedAt    DateTime @default(now()) @map("processed_at")

  @@map("processed_events")
}

model OrderStatusHistory {
  id        String   @id @default(uuid()) @db.Uuid
  orderId   String   @map("order_id") @db.Uuid
  fromStatus String?  @map("from_status")
  toStatus  String   @map("to_status")
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_status_history")
}

model OrderCounter {
  date     String @id
  sequence Int    @default(1)

  @@map("order_counters")
}
